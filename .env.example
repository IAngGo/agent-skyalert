# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL — when running via Docker Compose use the values below as-is.
# For local (non-Docker) dev, change host to localhost.
DATABASE_URL=postgresql://skyalert:skyalert@db:5432/skyalert

# Redis — when running via Docker Compose use the value below as-is.
REDIS_URL=redis://redis:6379/0

# SendGrid
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACyour_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886
