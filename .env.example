# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# REQUIRED — the app will not start without these.
# When running via Docker Compose, leave the values below as-is.
# For local (non-Docker) dev, change host to localhost.

DATABASE_URL=postgresql://skyalert:skyalert@db:5432/skyalert
REDIS_URL=redis://redis:6379/0

# Auth — generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_BASE_URL=http://localhost:8000

# OPTIONAL — the app starts without these, but notifications will be disabled.
# Alerts are still stored in the DB and visible in the dashboard.
#
# SendGrid (email alerts)
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=alerts@yourdomain.com
#
# Twilio (WhatsApp alerts)
TWILIO_ACCOUNT_SID=ACyour_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=+14155238886
